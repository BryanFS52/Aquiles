type TeamsScrum {
    id: ID!
    name: String
    members: String
    checklist: Checklist
    project: Project
}

type TeamsScrumPage {
    code: String
    data: [TeamsScrum]
    date: String
    totalPages: Int
    totalItems: Int
    currentPage: Int
    message: String
}

type TeamsScrumPageId {
    data: TeamsScrum
    date: String
    code: String
    message: String
}

input TeamsScrumInput {
    name: String!
    members: String!
    checklist: ChecklistInput
    project: ProjectInput
}

extend type Query {
    allTeamsScrums(page: Int, size: Int): TeamsScrumPage
    teamScrumById(id: ID!): TeamsScrumPageId
}

extend type Mutation {
    addTeamScrum(input: TeamsScrumInput!): Response
    updateTeamScrum(id: ID!, input: TeamsScrumInput): Response
    deleteTeamScrum(id: ID!): Response
}