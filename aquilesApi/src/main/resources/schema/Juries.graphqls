type Juries {
    id: ID!
    dateAssigned: String
    listChecklistSubstantiationLists: [Checklist]
}

type JuriesPage {
    code: String
    data: [Juries]
    date: String
    totalPages: Int
    totalItems: Int
    currentPage: Int
    message: String
}

type JuriesPageId {
    data: Juries
    date: String
    code: String
    message: String
}

input JuriesDto {
    dateAssigned: String
    listChecklistSubstantiationListsIds: [ID]
}

extend type Query {
    allJuries(page: Int, size: Int): JuriesPage
    juryById(id: Long!): JuriesPageId
}

extend type Mutation {
    addJury(input: JuriesDto): Response
    updateJury(id: Long!, input: JuriesDto): Response
    deleteJury(id: Long!): Response
}