type Justification {
    id: ID!
    documentNumber: String
    name: String
    description: String
    justificationFile: String
    justificationDate: String
    justificationHistory: String
    state: Boolean
    notificationId: ID
    justificationType: JustificationType
}

type JustificationPage {
    code: String
    data: [Justification]
    date: String
    totalPages: Int
    totalItems: Int
    currentPage: Int
    message: String
}

type JustificationPageId {
    data: Justification
    date: String
    code: String
    message: String
}

input JustificationDto {
    documentNumber: String
    name: String
    description: String
    justificationFile: String
    justificationDate: String
    justificationHistory: String
    state: Boolean
    notificationId: ID
    justificationTypeId: JustificationTypeDto
}

extend type Query {
    allJustifications(page: Int, size: Int): JustificationPage
    justificationById(id: ID!): JustificationPageId
}

extend type Mutation {
    addJustification(input: JustificationDto): Response
    updateJustification(id: ID!, input: JustificationDto): Response
    deleteJustification(id: ID!): Response
}