{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      // Añadir alias para las carpetas
      "@/*": ["./app/*"],
      "@components/*": ["./app/components/*"],
      "@routes/*": ["./app/(routes)/*"],
      "@styles/*": ["./app/styles/*"],
      "@lib/*": ["./app/lib/*"],
      "@utils/*": ["./app/utils/*"],
      "@hooks/*": ["./app/hooks/*"],
      "@public/*": ["./public/*"]
    },
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
