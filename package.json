{
    "name": "aquiles-monorepo",
    "private": true,
    "workspaces": [
        "frontend"
    ],
    "scripts": {
        "start:frontend": "npm --workspace frontend run dev",
        "start:aquilesApi": "cd aquilesApi && gradlew.bat bootRun",
         "dev": "concurrently --names \"FRONTEND,BACKEND\" --prefix-colors \"green,blue\" \"npm run start:frontend\" \"npm run start:aquilesApi\""
    },
    "devDependencies": {
        "concurrently": "^8.2.0"
    }
}